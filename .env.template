# ======= Google AI Studio (Gemini) 설정 =======
# AI 요약을 생성하기 위한 API Key
# [발급 방법]: https://aistudio.google.com/ 에 접속하여 로그인 후, 'Get API key' 메뉴에서 새로운 키를 발급받습니다.
GEMINI_API_KEY="your_gemini_api_key_here"

# (권장) 기본 Gemini 모델명
# 예: gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_MODEL="gemini-2.5-flash"

# (선택) 모델 자동 전환 후보군 (콤마 구분)
GEMINI_MODEL_CANDIDATES="gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite"

# ======= Gemini 호출 예산/복구 설정 (선택) =======
# 3시간 주기 기본 스케줄이라면 free-tier 20/day를 넘기지 않도록 16 정도를 권장합니다.
GEMINI_DAILY_REQUEST_BUDGET="16"

# 한 번의 파이프라인 런에서 실제 원격 Gemini 호출에 허용할 최대 횟수입니다.
# 비우면 daily budget / 하루 실행 횟수 기준으로 자동 계산합니다.
GEMINI_MAX_REMOTE_CALLS_PER_RUN=""

# 스케줄 간격(시간). run budget 자동 계산과 운영 로그 설명에 사용합니다.
PIPELINE_RUN_INTERVAL_HOURS="3"

# quota 고갈 감지 후 로컬 fallback 모드로 유지할 기본 시간(초)
GEMINI_QUOTA_BLOCK_SECONDS="300"

# ======= Notion 설정 =======
# 워크스페이스에서 발급받은 통합(Integration) 토큰 (secret_... 형식)
# [발급 방법]: https://www.notion.so/my-integrations 에 접속하여 '새 API 통합'을 생성하고 발급받는 시크릿 토큰입니다. 생성 후 데이터베이스 연결이 필요합니다.
NOTION_TOKEN="your_notion_integration_token_here"

# 사용자 및 키워드를 관리하는 Notion 데이터베이스 ID
# [발급 방법]: 사용할 Notion 데이터베이스 페이지를 웹브라우저에서 열었을 때, URL에서 'https://www.notion.so/myworkspace/데이터베이스ID?v=뷰ID' 형태에서 데이터베이스 ID 부분을 추출합니다. (32자리)
NOTION_DATABASE_ID="your_notion_database_id_here"

# (신규 도입) 프롬프트 동적 관리를 위한 별도의 프롬프트 전용 Notion 데이터베이스 ID
# [발급 방법]: 프롬프트 관리용 새 표(데이터베이스)를 만든 뒤 URL에서 32자리 ID를 추출해 기입합니다.
NOTION_PROMPT_DB_ID="your_notion_prompt_db_id_here"

# ======= 이메일(Gmail) 및 기타 발송 설정 =======
# 리포트를 발송할 송신자(봇)의 이메일 계정 (발송인의 역할)
# [발급 방법]: 본인의 구글(Gmail) 이메일 주소를 기입합니다.
SENDER_EMAIL="your_email@gmail.com"

# 2단계 인증 페이지에서 발급받은 16자리 '앱 비밀번호' (띄어쓰기 없이 입력)
# [발급 방법]: 구글 계정 관리 -> 보안 -> 2단계 인증 활성화 -> 최하단의 '앱 비밀번호'에서 새로운 앱용 비밀번호를 생성합니다.
SENDER_APP_PASSWORD="your_app_password_here"

# ======= Telegram 설정 =======
# Telegram 봇 토큰
# [발급 방법]: 텔레그램에서 'BotFather'를 검색하여 대화를 시작하고, '/newbot' 명령어를 통해 봇을 생성한 후 발급되는 HTTP API용 토큰입니다.
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Telegram Bot API 요청 timeout(초)
TELEGRAM_REQUEST_TIMEOUT_SECONDS="10"

# Telegram 메시지 1건당 최대 길이. 길면 자동 분할 전송합니다.
TELEGRAM_MESSAGE_MAX_LENGTH="3500"

# 오류/알림 등을 수신할 관리자 텔레그램용 고유 식별 Chat ID
# [발급 방법]: 텔레그램에서 '@userinfobot' 또는 만든 봇에게 메시지를 보낸 후 API를 통해 자신의 user id (chat id)를 확인합니다.
ADMIN_TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

# ======= 시스템 보안 설정 =======
# 피드백 서버 동작 시 외부 어뷰징 차단을 위한 검증 시크릿 키
# [발급 방법]: 터미널에서 `openssl rand -hex 32` 명령어를 치거나 임의의 복잡하고 긴 문자열을 임의로 타이핑하여 직접 지정하는 값입니다. 이 키가 서버와 이메일에 동일하게 박혀있어야만 별점 기능이 동작합니다.
WEBHOOK_SECRET="change_this_to_a_random_secret_string"

# 피드백 서버의 외부 접근 가능한 기본 URL (Docker/서버 배포 환경에 맞게 설정)
# [발급 방법]: 피드백 서버가 배포된 도메인 또는 IP 주소를 기입합니다.
FEEDBACK_BASE_URL="https://your-domain.com"

# ======= 로컬/CI SQLite 저장소 경로 (선택) =======
# 기본값: data/stock_project.db
# GitHub Actions에서는 이 경로를 캐시 복구/저장 대상으로 사용하면 실행 간 과거 데이터가 유지됩니다.
STOCK_DB_PATH="data/stock_project.db"

# ======= Naver API 설정 (선택) =======
# 네이버 검색어 트렌드 데어터를 가져오기 위한 API Key
# [발급 방법]: https://developers.naver.com/ -> 애플리케이션 등록 -> '데이터랩(검색어트렌드)' 선택 후 발급되는 Client ID와 Client Secret 기입.
NAVER_CLIENT_ID="your_naver_client_id_here"
NAVER_CLIENT_SECRET="your_naver_client_secret_here"

# ======= 커뮤니티 크롤링 토글 (선택) =======
# GitHub Actions 등 403이 잦은 환경에서는 false 권장
REDDIT_ENABLED="true"

# 커뮤니티 소스 allowlist. 비우면 기본값 `stockplus_insight,reddit_wallstreetbets`를 사용합니다.
# 선택 가능한 소스: stockplus_insight, blind_stock_lounge, dc_stock_gallery, naver_board, reddit_wallstreetbets
COMMUNITY_ENABLED_SOURCES=""

# ======= 외부 무료 소스 커넥터 (선택) =======
# true일 때만 data.go/OpenDART/SEC/FRED 최소 지표 수집을 실행합니다.
EXTERNAL_CONNECTORS_ENABLED="false"
# true일 때 커넥터 실행 텔레메트리를 SQLite에 저장합니다.
EXTERNAL_CONNECTOR_TELEMETRY_DB="true"
# true일 때 최근 1H/24H 운영 상태를 평가해 관리자 텔레그램 알림을 발송합니다.
EXTERNAL_CONNECTOR_ALERTS_ENABLED="true"
# 비어 있으면 ADMIN_TELEGRAM_CHAT_ID를 재사용합니다. 여러 명이면 콤마로 구분합니다.
EXTERNAL_CONNECTOR_ALERT_CHAT_IDS=""
EXTERNAL_CONNECTOR_ALERT_MIN_SAMPLES="2"
EXTERNAL_CONNECTOR_ALERT_FAILURE_RATE_1H="0.5"
EXTERNAL_CONNECTOR_ALERT_FAILURE_RATE_24H="0.3"
EXTERNAL_CONNECTOR_ALERT_AVG_LATENCY_MS="4000"
EXTERNAL_CONNECTOR_ALERT_COOLDOWN_MINUTES="180"

# OpenDART API 키
OPEN_DART_API_KEY=""
OPEN_DART_PAGE_COUNT="20"

# FRED API 키 및 샘플 시리즈
FRED_API_KEY=""
FRED_SERIES_ID="DFF"
FRED_SAMPLE_LIMIT="20"

# data.go 주식시세 OpenAPI (예시 URL + 서비스키)
DATA_GO_KR_API_KEY=""
DATA_GO_KR_STOCK_PRICE_URL=""
DATA_GO_KR_NUM_ROWS="20"

# SEC API 정책 준수를 위한 User-Agent
# SEC source를 활성화할 경우 실제 연락 가능한 이름/이메일을 직접 입력하세요.
# 예: "stock-project/1.0 (contact: ops-team@your-domain.com)"
SEC_USER_AGENT=""
