#!/bin/sh
# 커밋 창이 열릴 때 주니어 개발자를 위한 설명 템플릿을 자동으로 삽입하는 Hook

# 템플릿이 이미 포함되어 있거나 `--message` 등의 옵션으로 직접 메세지를 넣은 경우엔 건너뜀
if [ -z "$2" ] && ! grep -q "💡 주니어 개발자 학습 포인트" "$1"; then
    echo "" >> "$1"
    echo "# 📝 작업 요약 (Summary)" >> "$1"
    echo "# 핵심 변경 사항을 간략히 적어주세요." >> "$1"
    echo "" >> "$1"
    echo "# 🔍 상세 설명 (Details)" >> "$1"
    echo "# 바뀐 이유와 동작 방식에 대해 적어주세요." >> "$1"
    echo "" >> "$1"
    echo "# 💡 주니어 개발자 학습 포인트 (Learning Point)" >> "$1"
    echo "# 이번 작업에 쓰인 기술이나 꿀팁을 신입 개발자가 이해하기 쉽게 튜토리얼 톤으로 설명해주세요." >> "$1"
    echo "# 예: 'XX를 주의해야 하는 이유는 보안 때문입니다. 항상 YY 방식을 써주세요!'" >> "$1"
fi
